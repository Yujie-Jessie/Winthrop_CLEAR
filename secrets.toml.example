# ===================================================================
# secrets.toml  —  CONFIGURATION TEMPLATE
# ===================================================================
# 1. Rename this file to:  secrets.toml
# 2. Put it inside a folder named  .streamlit  next to app.py:
#        d:\CLEAR\.streamlit\secrets.toml
# 3. Replace the two placeholder values below with your real ones.
#
# NOTE: never share or commit this file — it contains private keys.
# ===================================================================

# Your PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL = "postgresql://user:password@host/dbname?sslmode=require"

# Your Anthropic API key from https://console.anthropic.com  (starts with sk-ant-)
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
